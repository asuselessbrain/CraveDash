model Cuisine {
    id            String        @id @default(uuid())
    name          String
    image         String?
    providerEmail String
    user          User          @relation("ProviderCuisines", fields: [providerEmail], references: [email])
    status        CuisineStatus @default(ACTIVE)
    createdAt     DateTime      @default(now())
    updatedAt     DateTime      @updatedAt

    categories Category[]

    @@map("cuisines")
}

enum CuisineStatus {
    ACTIVE
    INACTIVE
}
