model Category {
	id        String         @id @default(uuid())
	name      String
	cuisineId String
	cuisine   Cuisine        @relation(fields: [cuisineId], references: [id], onDelete: Cascade)
	image     String?
	status    CategoryStatus @default(ACTIVE)
	createdAt DateTime       @default(now())
	updatedAt DateTime       @updatedAt

	@@map("categories")
}

enum CategoryStatus {
	ACTIVE
	INACTIVE
}
